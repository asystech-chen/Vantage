@@ -766,6 +752,16 @@
   ${If} "$0" == "true"
     liteFirewallW::RemoveRule "$INSTDIR\${FileMainEXE}" "${BrandShortName} ($INSTDIR)"
   ${EndIf}
+
+  ; Vantage: Ask user whether to remove profile data
+  MessageBox MB_YESNO|MB_ICONQUESTION "$(UN_CLEANUP_USERDATA)" IDNO skip_cleanup
+    ; Remove Roaming profile
+    RmDir /r /REBOOTOK "$APPDATA\Vantage"
+    ; Remove Local profile (cache etc.)
+    RmDir /r /REBOOTOK "$LOCALAPPDATA\Vantage"
+    ; Remove registry key
