 Function un.onGUIEnd
   ${un.OnEndCommon}
 
-  ${If} $ShouldOpenSurvey == "1"
-    ; Though these values are sometimes incorrect due to bug 444664 it happens
-    ; so rarely it isn't worth working around it by reading the registry values.
-    ${WinVerGetMajor} $0
-    ${WinVerGetMinor} $1
-    ${WinVerGetBuild} $2
